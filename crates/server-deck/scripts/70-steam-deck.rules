# udev rule granting the deck user access to the Steam Deck controller's
# hidraw node. Without this, server-deck must run as root.
#
# Install:
#   sudo cp 70-steam-deck.rules /etc/udev/rules.d/
#   sudo udevadm control --reload
#   sudo udevadm trigger
#
# After reload, /dev/hidrawN for VID 0x28de PID 0x1205 is rw for the
# logged-in user (uaccess) and the deck group.

KERNEL=="hidraw*", ATTRS{idVendor}=="28de", ATTRS{idProduct}=="1205", \
    MODE="0660", GROUP="deck", TAG+="uaccess"
